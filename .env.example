# Copy this file to `.env` and fill in values.
# `.env` is gitignored.

# OpenHands SDK LLM configuration
LLM_API_KEY=
LLM_MODEL=openhands/claude-sonnet-4-5-20250929
# Optional, only if you use a custom LiteLLM/OpenAI-compatible endpoint
LLM_BASE_URL=

# GitHub token used to push to the TARGET repo and open PRs
GITHUB_TOKEN=

# Alternative name supported by the CLI (optional)
OPENHANDS_API_KEY=
